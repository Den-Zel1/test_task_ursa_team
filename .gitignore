# .gitignore для Python проектов

# ======================
# Python общие
# ======================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ======================
# Питонические файлы
# ======================
# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask
instance/
.webassets-cache

# Scrapy
.scrapy

# Sphinx
docs/_build/
doc/_build/

# PyBuilder
target/

# Jupyter
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# PyCharm
.idea/

# VS Code
.vscode/
*.code-workspace

# ======================
# Виртуальные окружения
# ======================
# ВАЖНО: исключить ВСЕ виртуальные окружения!
.venv/
venv/
my_fastapi_app/.venv/
env/
ENV/
env.bak/
venv.bak/
pythonenv*

# ======================
# Операционные системы
# ======================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Thumbs.db
Desktop.ini
*.lnk

# Linux
*~

# ======================
# IDE и редакторы
# ======================
# PyCharm
.idea/
*.iws
*.iml
*.ipr

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ======================
# Базы данных
# ======================
*.db
*.sqlite
*.sqlite3
*.db-journal

# ======================
# Логи и кэши
# ======================
*.log
logs/
*.pot
*.pyc

# ======================
# Тестовые данные
# ======================
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ======================
# Пакеты и зависимости
# ======================
# Poetry
.poetry/

# Pipenv
Pipfile.lock

# pdm
.pdm.toml

# ======================
# Переменные окружения
# ======================
../.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.env

# ======================
# Документация
# ======================
docs/_build/

# ======================
# Статические файлы
# ======================
*.css.map
*.js.map

# ======================
# Миграции (исключаем только для собственных проектов)
# ======================
# Если вы создаете библиотеку, раскомментируйте:
# migrations/
.dev
